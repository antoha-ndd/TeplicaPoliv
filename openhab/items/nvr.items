// conf/items/nvr.items — каналы видеорегистратора (binding ipcamera)
// Things: ipcamera:generic:nvr1 … nvr10 (см. openHAB Things)

Group gNVR "Видеонаблюдение" <camera>

// Канал 1
Image  NVR_Cam1_Image     "NVR Camera1"     <camera> (gNVR) { channel="ipcamera:generic:nvr1:image" }
String NVR_Cam1_ImageUrl  "NVR Camera1"     <camera> (gNVR) { channel="ipcamera:generic:nvr1:imageUrl" }
String NVR_Cam1_MjpegUrl  "NVR Camera1"     <camera> (gNVR) { channel="ipcamera:generic:nvr1:mjpegUrl" }

// Каналы 2–10
String NVR_Cam2_ImageUrl  "NVR Camera2"     <camera> (gNVR) { channel="ipcamera:generic:nvr2:imageUrl" }
String NVR_Cam2_MjpegUrl  "NVR Camera2"     <camera> (gNVR) { channel="ipcamera:generic:nvr2:mjpegUrl" }
String NVR_Cam3_ImageUrl  "NVR Camera3"     <camera> (gNVR) { channel="ipcamera:generic:nvr3:imageUrl" }
String NVR_Cam3_MjpegUrl  "NVR Camera3"     <camera> (gNVR) { channel="ipcamera:generic:nvr3:mjpegUrl" }
